# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
# Default model. Lightweight alternative: qwen (e.g., qwen2.5:0.5b or qwen2.5:1.5b)
OLLAMA_MODEL=llama3.2

# Optional
SYSTEM_PROMPT=You are a helpful assistant running locally. Be concise.
REQUEST_TIMEOUT_MS=60000
# Stream the model's reply into the terminal. Set to 0 to disable.
STREAM_ENABLED=1
DEBUG=0
