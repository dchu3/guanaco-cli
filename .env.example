# guanaco-cli configuration. Loaded from <cwd>/.env (if present).
# You can also export these as plain env vars in your shell profile.

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
# Default model.
OLLAMA_MODEL=qwen3.5:0.8b

# Optional
SYSTEM_PROMPT=You are a helpful assistant running locally. Be concise.
REQUEST_TIMEOUT_MS=60000
# Stream the model's reply into the terminal. Set to 0 to disable.
STREAM_ENABLED=1
DEBUG=0

# Debug log file. All debug/error lines and stderr (e.g. errors from Mastra or
# pi-tui that the TUI overwrites on screen) are appended here so they can be
# recovered with `/log` or by opening the file. Defaults to
# ~/.guanaco/logs/debug.log when unset.
# GUANACO_LOG_FILE=/tmp/guanaco-debug.log

# Model Generation Parameters (Optional)
# Temperature: The temperature of the model (default: 0.8)
OLLAMA_TEMPERATURE=0.8
# Top P: The top-p of the model (default: 0.9)
OLLAMA_TOP_P=0.9
# Context window size (default: 2048 or model-defined)
OLLAMA_NUM_CTX=2048

# ───────────────────────────────────────────────────────────────────────
# SDLC Harness (Mastra-coordinated agent team)
# ───────────────────────────────────────────────────────────────────────
# Provider for the harness agents: 'local' (ollama-ai-provider against
# OLLAMA_BASE_URL) or 'cloud' (ollama-cloud/* model router).
OLLAMA_PROVIDER=local
# Required only when OLLAMA_PROVIDER=cloud.
# OLLAMA_API_KEY=

# Per-role model overrides (fall back to built-in defaults).
# Aggressive local defaults run every SDLC role on a capable coder-tuned model.
# HARNESS_MODEL_ORCHESTRATOR=qwen2.5-coder:7b
# HARNESS_MODEL_PRODUCT=qwen2.5-coder:7b
# HARNESS_MODEL_ARCHITECT=qwen2.5-coder:7b
# HARNESS_MODEL_CODER=qwen2.5-coder:7b
# HARNESS_MODEL_REVIEWER=qwen2.5-coder:7b
# HARNESS_MODEL_TESTER=qwen2.5-coder:7b

# Loop budgets.
HARNESS_MAX_REVIEW_CYCLES=4
HARNESS_MAX_TEST_CYCLES=4
# Max product ⇄ architect plan-refinement rounds (0 = product→architect, no
# back-and-forth). Each round adds a product + an architect turn.
HARNESS_MAX_PLAN_CYCLES=0
# Max Mastra tool-loop steps per agent turn. Defaults to 12.
HARNESS_MAX_AGENT_STEPS=12

# When 1, the harness commits its work on a new feature/<slug> branch
# without asking. When 0, it pauses at finalize for approval.
HARNESS_AUTO_COMMIT=1
# When 1, a dirty working tree is auto-stashed before the run and restored
# afterwards (instead of hard-blocking with 'dirty-tree'). When 0, the harness
# requires a clean tree before it will run with auto-commit on.
HARNESS_AUTO_STASH=1
# When 1, the harness pauses at intake for the human to confirm/refine the plan.
HARNESS_HUMAN_IN_LOOP_INTAKE=0

# Per shell-tool-call timeout (ms).
HARNESS_TOOL_TIMEOUT_MS=300000
# Per agent-turn *inactivity* timeout (ms). Aborts a turn only when no tokens
# have streamed for this long (a stalled LLM stream); a slow-but-productive
# turn is NOT killed just for being long. Keep this > HARNESS_TOOL_TIMEOUT_MS
# so a legitimate tool call isn't mistaken for a stall. 0 = off.
HARNESS_AGENT_TIMEOUT_MS=300000
# Per agent-turn *hard* wall-clock cap (ms); never reset. Bounds a runaway
# turn that never stalls but never finishes. Defaults to 10 minutes; set to
# 0 to disable.
HARNESS_AGENT_HARD_TIMEOUT_MS=600000
# Max streamed bytes per agent turn before the harness truncates and stops
# the turn (safety cap against runaway models). Defaults to 1 MB.
HARNESS_MAX_TURN_OUTPUT_BYTES=1000000
# Max total wall-clock time for a full harness run (ms). 0 = off (default).
# HARNESS_MAX_WALL_CLOCK_MS=0
# Repo root the harness is jailed to (defaults to process.cwd()).
# HARNESS_REPO_ROOT=

