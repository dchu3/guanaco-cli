# Guanaco CLI template configuration. Loaded from <cwd>/.env (if present).
# Plain exported env vars in your shell profile also work.

# Ollama HTTP endpoint.
OLLAMA_BASE_URL=http://localhost:11434

# App title shown in the top-right of the TUI header (defaults to "Guanaco CLI").
# APP_TITLE=Guanaco CLI
# Default model (pull first with: ollama pull <model>).
OLLAMA_MODEL=qwen2.5:0.5b

# Optional system prompt prepended to every chat.
SYSTEM_PROMPT=You are a helpful assistant running locally. Be concise.

# Request timeout (ms).
REQUEST_TIMEOUT_MS=60000
# Stream the model's reply into the terminal (0 disables).
STREAM_ENABLED=1
# Verbose debug log to stderr + the log file (0/1).
DEBUG=0

# Debug log file (defaults to ~/.guanaco-cli/logs/debug.log).
# GUANACO_CLI_LOG_FILE=/tmp/guanaco-cli-debug.log

# Generation parameters (optional).
OLLAMA_TEMPERATURE=0.8
OLLAMA_TOP_P=0.9
# Context window size (model default applies when unset). Bump for longer chats.
# OLLAMA_NUM_CTX=4096
# Max tokens generated per reply (unset = model default).
# OLLAMA_NUM_PREDICT=512

# Model "thinking" (qwen3 reasoning `imd…` blocks). 0 = off (clean chat output,
# recommended), 1 = on. Ignored by models without thinking. Requires Ollama >= 0.9.
# Flags --think / --no-think override this for a single run.
OLLAMA_THINK=0