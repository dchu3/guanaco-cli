{
  "name": "guanaco-cli",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Interactive CLI for connecting to local LLMs via Ollama. Guanaco is a wild version of Llama.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.74.0",
    "@mastra/core": "^1.43.0",
    "chalk": "^5.6.2",
    "marked": "^18.0.3",
    "ollama-ai-provider": "^1.2.0",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  }
}
